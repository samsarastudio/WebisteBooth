# Required — use a long random string in production
PAYLOAD_SECRET=change-me-to-a-long-random-string

# SQLite database — path is resolved to an absolute file at runtime (see scripts/start-production.mjs)
DATABASE_URI=file:./data/frameflix.db

# Public URL — must match your Cloudflare Tunnel hostname
# Production: https://inmomentservices.com
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# Parent brand link (navbar/footer)
NEXT_PUBLIC_PARENT_URL=https://inmomentservices.com

# Optional — lead email notifications via Resend
RESEND_API_KEY=
LEAD_NOTIFY_EMAIL=hello@inmomentservices.com
LEAD_NOTIFY_PHONE=(416) 555-1234
# RESEND_FROM_EMAIL=FrameFlix <hello@inmomentservices.com>

# OpenClaw bot — push blog posts via POST /api/bot/posts
OPENCLAW_API_KEY=

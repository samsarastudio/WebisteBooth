# Required — use a long random string in production
PAYLOAD_SECRET=change-me-to-a-long-random-string

# SQLite database file (created automatically)
DATABASE_URI=file:./data/frameflix.db

# Public URL — set to your FrameFlix subdomain in production
# Example: https://frameflix.inmoment.com
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# Parent brand (inmoment main site)
NEXT_PUBLIC_PARENT_URL=https://inmoment.com

# Optional — lead email notifications via Resend
RESEND_API_KEY=
LEAD_NOTIFY_EMAIL=frameflix@inmoment.com
LEAD_NOTIFY_PHONE=(416) 555-1234
# RESEND_FROM_EMAIL=FrameFlix by inmoment <onboarding@resend.dev>

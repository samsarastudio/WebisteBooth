# Normalize line endings to LF in the repo to avoid CRLF/LF churn
# between Windows dev machines and the Linux Raspberry Pi.
* text=auto eol=lf

# Keep Windows-specific scripts as CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets — never touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.svg text
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.pdf binary
*.db binary
*.mp4 binary
*.webm binary
